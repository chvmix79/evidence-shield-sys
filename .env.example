# Supabase Configuration
# Get these values from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# AI Configuration - IMPORTANTE: NO usar prefijo VITE_ para API keys secretas
# Las variables con prefijo VITE_ son EXPUESTAS públicamente en el frontend
# Esta key debe usarse solo en el servidor (server/api.ts)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Webhook secret for server
WEBHOOK_SECRET=your-webhook-secret

# Sentry Error Monitoring
# Get your DSN from: https://sentry.io/settings/projects/ → select project → Client Keys (DSN)
# Only needed in production — if not set, Sentry is safely disabled
VITE_SENTRY_DSN=https://your-dsn.ingest.us.sentry.io/project

# Sentry source map upload (CI/CD only — never commit this)
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=chv-riskinsight
SENTRY_PROJECT=react-app